---
import { Icon } from "astro-icon/components";
import "../styles/variables/colours.css";
import "../styles/variables/typography.css";

const { skill, lag } = Astro.props;
---

<li data-lag={lag}>
    <div>
        <h3>{skill.name}</h3>
        <p>{skill.description}</p>
    </div>
    <ul>
        {
            skill.iconList.map((icon: Icon) => (
                <li>
                    <Icon name={icon.name} title={icon.title} size={"1.5em"} />
                </li>
            ))
        }
    </ul>
</li>

<style>
    li:not(li > ul > li) {
        display: flex;
        flex-direction: column;
        justify-content: space-between;

        font-size: var(--fs-sm);

        border: 1px solid var(--text-primary);
        border-radius: 0.25rem;

        padding: 1rem;
        background-color: var(--background-colour-transparent);
        backdrop-filter: blur(1px);

        h3 {
            margin-bottom: 0.5rem;
        }

        ul {
            display: flex;
            gap: 1rem;

            list-style: none;

            padding: 0;

            li {
                margin: 0;
            }
        }
    }
</style>
