---
import "../styles/variables.css";
---

<header>
    <p>&lt;robeecodes /&gt;</p>
    <nav>
        <ul>
            <li><a href="#about-me">About</a></li>
            <li><a href="#projects">Projects</a></li>
            <li><a href="#contact">Contact</a></li>
        </ul>
    </nav>
</header>
<style>
    header {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        padding: 0.5rem 1rem;

        font-size: var(--fs-sm);
        background-color: var(--header-footer-colour);

        position: sticky;
        top: 0;
        z-index: 100;

        height: 2.5rem;

        p {
            grid-column: 2;
            margin-bottom: 0;
        }

        nav {
            grid-column: 3;

            ul {
                display: flex;
                justify-content: end;
                list-style: none;
                gap: 1.5rem;

                li {
                    margin-bottom: 0;
                }

                a {
                    color: var(--text-colour);
                    text-decoration: none;

                    &:hover {
                        color: var(--text-secondary);
                    }

                    &:active {
                        color: var(--text-secondary);
                    }

                    &:focus {
                        color: var(--text-secondary);
                    }
                }
            }
        }
    }
</style>
